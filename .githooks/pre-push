#!/usr/bin/env bash
set -euo pipefail

PACKAGE_VERSION="$(awk -F '"' '/__version__/ { print $2; exit }' src/fastapiobserver/_version.py)"
if [[ -z "$PACKAGE_VERSION" ]]; then
  echo "[pre-push] Failed to resolve package version from src/fastapiobserver/_version.py"
  exit 1
fi

echo "[pre-push] Validating changelog section for ${PACKAGE_VERSION}"
uv run python scripts/extract_changelog_section.py "$PACKAGE_VERSION" >/dev/null

echo "[pre-push] Running Ruff"
uv run ruff check .

echo "[pre-push] Running mypy"
uv run mypy src

echo "[pre-push] Running pytest"
uv run pytest -q

echo "[pre-push] All checks passed."
